# Grabarr qBittorrent Webhook Configuration
# Copy this file to ~/bin/qbt-grabarr.env on your seedbox and fill in the values

# Required: Grabarr API endpoint
GRABARR_API_URL="https://hooks.dppeppel.me/grabarr/api/v1/jobs"

# Required: Cloudflare Access credentials
GRABARR_CF_CLIENT_ID="your-client-id-here.access"
GRABARR_CF_CLIENT_SECRET="your-client-secret-here"

# Optional: Custom download configuration
# Uncomment and adjust values as needed for your use case

# Number of parallel file transfers (default: 1)
#GRABARR_TRANSFERS=1

# Overall bandwidth limit (default: 10M)
# Examples: 1M, 10M, 100M, 1G
#GRABARR_BW_LIMIT="10M"

# Per-file bandwidth limit (default: 10M)
#GRABARR_BW_LIMIT_FILE="10M"

# Number of checkers to run in parallel (default: 1)
#GRABARR_CHECKERS=1

# Number of streams to use for multi-threaded downloads (default: 1)
#GRABARR_MULTI_THREAD_STREAMS=1

# Optional: File type filtering (security)
# Space-separated list of allowed file extensions (without dots)
# Only files with these extensions will be downloaded
# Default: "mkv mp4 avi mov wmv flv webm m4v mpg mpeg ts m2ts srt sub ass ssa idx vtt"
# Uncomment to customize the allowed extensions
#GRABARR_ALLOWED_EXTENSIONS="mkv mp4 avi mov wmv flv webm m4v mpg mpeg ts m2ts srt sub ass ssa idx vtt"
